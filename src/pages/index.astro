    <!-- Swiper for services mobile slider -->
    <script>
      import Swiper from 'swiper';
      import { Navigation, Pagination } from 'swiper/modules';
      import 'swiper/css';
      import 'swiper/css/navigation';
      import 'swiper/css/pagination';

      // The services slider is a mobile-only presentation of the desktop grid.
      // Initialise it only at the mobile breakpoint so the desktop DOM carries no
      // hidden, initialised Swiper. `rewind` (not `loop`) keeps every one of the
      // four source slides deterministically reachable via the nav arrows.
      const mq = window.matchMedia('(max-width: 768px)');
      let servicesSwiper = null;
      const sliderEl = document.querySelector('.services-slider');
      function syncServicesSlider() {
        if (!sliderEl) return;
        if (mq.matches && !servicesSwiper) {
          sliderEl.classList.add('swiper');
          servicesSwiper = new Swiper(sliderEl, {
            modules: [Navigation, Pagination],
            slidesPerView: 1,
            navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
            pagination: { el: '.swiper-pagination', clickable: true },
            rewind: true,
          });
        } else if (!mq.matches && servicesSwiper) {
          servicesSwiper.destroy(true, true);
          servicesSwiper = null;
          sliderEl.classList.remove('swiper');
        }
      }
      syncServicesSlider();
      mq.addEventListener('change', syncServicesSlider);
    </script>


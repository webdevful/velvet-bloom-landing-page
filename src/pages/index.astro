---
import "../styles/velvet-bloom.css";
import "@fortawesome/fontawesome-free/css/all.min.css";
import "swiper/css";

const logo = "/logo.png";
const heroImg = "/assets/img/hero-face.jpg";
const popupImg = "/assets/img/popup-spa.jpg";
const formImg = "/assets/img/pricing-leaf.jpg";
const pricingImg = "/assets/img/pricing-flatlay.jpg";

const services = [
  {
    id: "cosmetology",
    name: "Cosmetology",
    img: "/assets/img/service-cosmetology.jpg",
    copy: "Professional skin treatments, cleansing rituals, and renewal care tailored to your complexion and pace.",
  },
  {
    id: "massage",
    name: "Massage",
    img: "/assets/img/service-massage.jpg",
    copy: "Slow therapeutic bodywork that eases tension, restores calm, and helps you leave lighter.",
  },
  {
    id: "nails",
    name: "Nails service",
    img: "/assets/img/service-nails.jpg",
    copy: "Clean manicures and pedicures with polished detail, premium products, and a soft finish.",
  },
  {
    id: "makeup",
    name: "Makeup",
    img: "/assets/img/service-makeup.jpg",
    copy: "Natural, event-ready, and editorial looks designed to enhance your own features.",
  },
];

const standards = [
  {
    icon: "fa-solid fa-seedling",
    copy: "Every tool, towel, and treatment station is prepared with careful hygiene standards before your visit begins.",
  },
  {
    icon: "fa-solid fa-award",
    copy: "Your appointment is handled by trained specialists who balance technical precision with an easy, attentive touch.",
  },
  {
    icon: "fa-solid fa-spa",
    copy: "Soft light, warm textures, and thoughtful pacing make each service feel calm from arrival through checkout.",
  },
];

const prices = ["Cosmetology", "Massage", "Nails service", "Makeup"];
const priceRows = [
  ["Face cleaning, vacuum", "$45"],
  ["Face cleaning, ultrasonic", "$45"],
  ["Face cleaning, mechanical", "$45"],
  ["Azelaic peeling", "$45"],
  ["Salicylic peeling", "$45"],
  ["Hydrating complex care", "$45"],
];

const gallery = [
  ["/assets/img/gallery-salon.jpg", "Salon interior"],
  ["/assets/img/gallery-hairwash.jpg", "Hair washing service"],
  ["/assets/img/gallery-brushes.jpg", "Salon brushes"],
  ["/assets/img/gallery-stylist.jpg", "Polished manicure"],
  ["/assets/img/gallery-spa.jpg", "Spa treatment room"],
];

const reviews = [
  ["Amanda Dolson", "The room felt calm the moment I walked in. My facial was gentle, unrushed, and tailored to my skin, and I left with the softest glow I have had all season.", 5],
  ["Sarah Mitchell", "Velvet Bloom has become my monthly reset. The team remembers the small details, explains every step, and makes a simple appointment feel like a retreat.", 5],
  ["Jessica Park", "I booked a massage and manicure before a weekend event, and everything was beautifully paced. The space is serene, and the finish lasted.", 4],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Velvet Bloom | Beauty Salon & Day Spa</title>
    <meta name="description" content="Velvet Bloom is a beauty salon and day spa for careful skin, body, nail, and makeup services." />
  </head>
  <body>
    <section class="section popup" aria-hidden="true">
      <div class="popup-wrapper">
        <button class="popup-close" type="button" aria-label="Close booking form">
          <span></span>
          <span></span>
        </button>
        <div class="popup-left-part">
          <div class="popup-head">
            <h2 class="head-forum">Book a visit</h2>
            <div class="decor-circle" aria-hidden="true"></div>
          </div>
          <form class="popup-form">
            <input class="form-input" type="text" placeholder="Your name" required />
            <input class="form-input" type="tel" placeholder="Phone number" required />
            <input class="form-input" type="text" placeholder="Service" />
            <button class="button popup-button" type="submit">
              <span>Send</span>
              <span class="arrow" aria-hidden="true"></span>
            </button>
          </form>
        </div>
        <img src={popupImg} alt="Spa treatment room" class="popup-image" width="497" height="620" loading="lazy" />
      </div>
    </section>

    <section class="section header">
      <nav class="navbar" aria-label="Primary navigation">
        <div class="container navbar-container">
          <a href="#Home" class="navbar-logo" aria-label="Velvet Bloom home">
            <img src={logo} alt="Velvet Bloom" class="image-logo" width="188" height="48" />
          </a>
          <div class="navbar-menu">
            <div class="navbar-links-wrapp">
              <div class="header-links-wrapp">
                <a href="#Services" class="header-nav-link">Services</a>
                <a href="#Standarts" class="header-nav-link">Standards</a>
                <a href="#Price" class="header-nav-link">Pricing</a>
                <a href="#Gallery" class="header-nav-link">Gallery</a>
              </div>
              <a href="#" data-open-popup class="button small-button button-mob">Contacts us</a>
            </div>
          </div>
          <a href="#" data-open-popup class="button small-button button-desk">Contacts us</a>
          <button class="nav-button" type="button" aria-label="Open menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </nav>
    </section>

    <main id="Home">
      <section class="section hero-section">
        <div class="container">
          <div class="hero-block-wrapp">
            <div class="hero-block-left">
              <h1>Feel <span class="italic">renewed</span> and <span class="italic">beautiful</span> at Velvet Bloom</h1>
            </div>
            <img src={heroImg} alt="Beauty treatment" class="hero-block-image" width="670" height="589" loading="eager" />
            <p class="hero-subhead">Calm renewal, polished care, and a softly restored glow.</p>
            <div class="hero-block-button">
              <a href="#" data-open-popup class="button">
                <span>Book a visit</span>
                <span class="arrow" aria-hidden="true"></span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <section id="Services" class="section big-top-margin">
        <div class="container">
          <h2>Our services</h2>
          <div class="services-grid">
            {services.map((service, index) => (
              <a href={`#${service.id}`} class={`service-item ${["first", "second", "third", "fourth"][index]}`}>
                <div class="services-item" id={service.id}>
                  <div class="services-item-left">
                    <div class="services-item-head">{service.name}</div>
                    <p class="service-item-description">{service.copy}</p>
                    <div class="services-link"><span class="arrow small" aria-hidden="true"></span></div>
                  </div>
                  <div class="services-item-right">
                    <img src={service.img} alt={service.name} class="image" width="300" height="340" loading="lazy" />
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="services-slider swiper" aria-label="Services carousel">
            <div class="services-mask swiper-wrapper">
              {services.map((service, index) => (
                <div class="services-slide swiper-slide" aria-label={`${index + 1} of ${services.length}`}>
                  <a href={`#${service.id}`}>
                    <div class="services-item">
                      <div class="services-item-left">
                        <div class="services-item-head">{service.name}</div>
                        <p class="service-item-description">{service.copy}</p>
                        <div class="services-link"><span class="arrow small" aria-hidden="true"></span></div>
                      </div>
                      <div class="services-item-right">
                        <img src={service.img} alt={service.name} class="image" loading="lazy" />
                      </div>
                    </div>
                  </a>
                </div>
              ))}
            </div>
            <button class="left-arrow" type="button" aria-label="Previous service"><span class="arrow left" aria-hidden="true"></span></button>
            <button class="right-arrow" type="button" aria-label="Next service"><span class="arrow" aria-hidden="true"></span></button>
            <div class="slider-nav" aria-hidden="true"></div>
          </div>
        </div>
      </section>

      <section id="Standarts" class="section">
        <div class="container">
          <h2>Standards of care</h2>
          <div class="standarts-wrapp">
            {standards.map((standard, index) => (
              <div class="standart-item">
                <div class="standart-image-wrapp">
                  <i class={`standart-icon ${standard.icon}`} aria-hidden="true"></i>
                  <span class={`service-image-absolute position-${index + 1}`} aria-hidden="true"></span>
                </div>
                <p class="service-text">{standard.copy}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="pricing-wrapp">
            <div class="pricng-images-wrapp">
              <img src={pricingImg} alt="Beauty treatment essentials" class="pricing-main-image" width="547" height="760" loading="lazy" />
              <img src={popupImg} alt="Spa product detail" class="pricing-overlap-image" width="276" height="276" loading="lazy" />
            </div>
            <div class="pricing-table">
              <div id="Price" class="pricing-head">
                <h2 class="align-left">Types of procedures &amp; pricing</h2>
                <div class="pricing-dropdowns-wrapp">
                  {prices.map((price) => (
                    <div class="pricing-dropdown">
                      <button class="dropdown-toggle" type="button" aria-expanded="false">
                        <span>{price}</span>
                        <span class="dropdown-icon" aria-hidden="true"></span>
                      </button>
                      <div class="dropdown-list">
                        {priceRows.map((row) => (
                          <div class="dropdown-inner-item"><span>{row[0]}</span><span>{row[1]}</span></div>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <div class="pricing-button">
                <a href="#" data-open-popup class="button">
                  <span>Book a visit</span>
                  <span class="arrow" aria-hidden="true"></span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="Gallery" class="section">
        <div class="container">
          <h2 class="align-left mob-left">Gallery of our space</h2>
          <div class="gallery-stack">
            {gallery.map(([src, alt], index) => (
              <div class={[0, 1, 2, 3].includes(index) ? ["gallery-first", "gallery-second", "gallery-third", "gallery-fourth"][index] : "mob-none"}>
                <img src={src} alt={alt} class="gallery-image" loading="eager" />
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="section reviews-section">
        <div class="container">
          <div class="reviews-wrapp">
            <h2 class="align-left">Reviews</h2>
            {reviews.map(([name, text, rating], index) => (
              <div class={`reviews-item ${["", "second", "third"][index]}`}>
                <div>
                  <p class="reviews-name">{name}</p>
                </div>
                <div>
                  <div class="starts-block" aria-label={`${rating} out of 5 stars`}>
                    {[1, 2, 3, 4, 5].map((star) => <span class={star <= rating ? "star full" : "star"} aria-hidden="true"></span>)}
                  </div>
                  <p class="reviews-text">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="form-wrapper">
            <div class="form-inner">
              <div class="form-head">
                <h2>Need help choosing your next service?</h2>
                <p class="form-subhead">Share your phone number and our studio will call you back.</p>
              </div>
              <form class="form">
                <input class="input" type="tel" placeholder="number" required />
                <button class="submit-button" type="submit">Submit</button>
              </form>
            </div>
            <img src={formImg} alt="Form decor" class="form-left-image" loading="eager" />
            <span class="form-right-image" aria-hidden="true"></span>
          </div>
        </div>
      </section>
    </main>

    <section class="section footer">
      <footer class="container" aria-label="Footer">
        <div class="footer-wrapp">
          <img src={logo} alt="Velvet Bloom" class="footer-logo" width="188" height="48" loading="lazy" />
          <div class="footer-top-block">
            <div class="footer-info">
              <p>334 Oakland Drive Brooklyn, NY 11218</p>
              <p><a href="mailto:hello@velvetbloom.com">hello@velvetbloom.com</a></p>
              <p><a href="tel:+15551234567">+1 555 123 4567</a></p>
            </div>
            <div class="social-networks">
              <a href="https://www.facebook.com/" aria-label="Facebook">f</a>
              <a href="https://twitter.com/" aria-label="Twitter">x</a>
              <a href="https://www.instagram.com/" aria-label="Instagram">i</a>
            </div>
            <div class="footer-menu">
              <a href="/privacy-policy">Privacy notice</a>
              <a href="/license">License</a>
              <a href="/ui-kit">UI kit</a>
              <a href="/changelog">Changelog</a>
            </div>
          </div>
          <div class="footer-bottom-block">
            <p class="footer-feedback-text">Need help choosing your next service?</p>
            <a href="#" data-open-popup class="button">
              <span>Book a visit</span>
              <span class="arrow" aria-hidden="true"></span>
            </a>
            <span class="footer-decor" aria-hidden="true"></span>
          </div>
          <p class="powered-by">Powered by WebDevful</p>
        </div>
      </footer>
    </section>

    <div class="lightbox-overlay" aria-hidden="true">
      <button class="lightbox-close" type="button" aria-label="Close gallery">&times;</button>
      <img src="" alt="" />
    </div>

    <script>
      import "../scripts/main.js";
    </script>
  </body>
</html>

{
  "slug": "velvet-bloom",
  "sourceUrl": "https://magnolia-template.webflow.io/",
  "sourceLabel": "Magnolia (Webflow hosted template)",
  "description": "Measured Magnolia-to-Velvet Bloom source-design contract. Section 2 checks pin the source 2x2 service grid, card split, transparent organic two-contour photo geometry, typography rhythm, and desktop-only grid/mobile-only slider topology. Section 4 checks pin the source 547x814 pricing-media composite silhouette reconstructed from approved local photography.",
  "checks": [
    {
      "id": "services-desktop-grid",
      "description": "Our Services keeps the source two-column desktop grid.",
      "selector": ".services-grid",
      "property": "grid-template-columns",
      "expected": "1fr 1fr",
      "severity": "error"
    },
    {
      "id": "services-grid-gap",
      "description": "Our Services keeps the source 16px card gutter.",
      "selector": ".services-grid",
      "property": "gap",
      "expected": "16px",
      "severity": "error"
    },
    {
      "id": "services-card-columns",
      "description": "Desktop cards keep the source text-to-photo split.",
      "selector": ".services-item",
      "property": "grid-template-columns",
      "expected": ".5fr 1fr",
      "severity": "error"
    },
    {
      "id": "services-card-padding",
      "description": "Desktop cards keep the source inset geometry.",
      "selector": ".services-item",
      "property": "padding",
      "expected": "20px 20px 40px 40px",
      "severity": "error"
    },
    {
      "id": "services-copy-leading",
      "description": "Service copy inherits the source 1.5 reading rhythm.",
      "selector": ".service-item-description",
      "property": "line-height",
      "expected": "1.5",
      "severity": "error"
    },
    {
      "id": "services-photo-aspect",
      "description": "Local service photos keep the measured source composite proportion near 398x449.",
      "selector": ".image",
      "property": "aspect-ratio",
      "expected": "398 / 449",
      "severity": "error"
    },
    {
      "id": "services-photo-not-regular-ellipse",
      "description": "The source does not use border-radius for the service photo contour; the organic alpha contour must remain independently clipped.",
      "selector": ".image",
      "property": "border-radius",
      "expected": "0",
      "severity": "error"
    },
    {
      "id": "services-photo-no-concentric-shadow",
      "description": "The source outer hairline is not a concentric box-shadow ring.",
      "selector": ".image",
      "property": "box-shadow",
      "expected": "none",
      "severity": "error"
    },
    {
      "id": "services-photo-organic-mask",
      "description": "Each local service photo is clipped by its measured organic inner contour.",
      "selector": ".image",
      "property": "clip-path",
      "expected": "var(--service-photo-mask)",
      "severity": "error"
    },
    {
      "id": "services-outline-independent-layer",
      "description": "The differently shaped outer hairline remains an independent scalable layer over the photo mask.",
      "selector": ".service-image-outline",
      "property": "position",
      "expected": "absolute",
      "severity": "error"
    },
    {
      "id": "services-desktop-slider-hidden",
      "description": "The mobile Swiper cannot leak below the desktop 2x2 grid.",
      "selector": "#Services .services-slider",
      "property": "display",
      "expected": "none",
      "severity": "error"
    },
    {
      "id": "pricing-composite-aspect",
      "description": "The pricing media column keeps the source 547x814 transparent-composite silhouette.",
      "selector": ".pricng-images-wrapp",
      "property": "aspect-ratio",
      "expected": "547 / 814",
      "severity": "error"
    },
    {
      "id": "pricing-primary-full-width",
      "description": "The upper pricing photograph spans the full source media column instead of becoming a narrow right-aligned panel.",
      "selector": ".pricing-main-image",
      "property": "width",
      "expected": "100%",
      "severity": "error"
    },
    {
      "id": "pricing-primary-height",
      "description": "The upper photograph preserves the measured 83.8 percent height of the composite canvas.",
      "selector": ".pricing-main-image",
      "property": "height",
      "expected": "83.8%",
      "severity": "error"
    },
    {
      "id": "pricing-secondary-right-anchor",
      "description": "The smaller pricing photograph stays anchored to the bottom-right of the source composite.",
      "selector": ".pricing-overlap-image",
      "property": "right",
      "expected": "0",
      "severity": "error"
    },
    {
      "id": "pricing-secondary-width",
      "description": "The smaller pricing photograph preserves the measured 48.8 percent source-composite width.",
      "selector": ".pricing-overlap-image",
      "property": "width",
      "expected": "48.8%",
      "severity": "error"
    }
  ],
  "design_tokens": {
    "fonts": {
      "heading": "Forum, serif",
      "body": "Cormorant, serif",
      "accent": "Open Sans, sans-serif"
    },
    "colors": {
      "paper": "#fdfaf7",
      "ink": "#000000",
      "warmBeige": "#f8e8da",
      "peach": "#f8c497",
      "white": "#ffffff",
      "dark": "#1f2024",
      "line": "#ece0dc"
    }
  },
  "sections": [
    "booking-popup-modal",
    "navbar-fixed-transparent",
    "hero-split-layout",
    "services-4-card-grid",
    "standards-3-icon-cards",
    "pricing-accordion-dropdowns",
    "gallery-5-image-masonry",

{
  "slug": "velvet-bloom",
  "sourceUrl": "https://magnolia-template.webflow.io/",
  "sourceLabel": "Magnolia (Webflow hosted template)",
  "description": "Measured Magnolia-to-Velvet Bloom source-design contract. Section 2 checks pin the source 2x2 service grid, card split, transparent organic two-contour photo geometry, typography rhythm, and desktop-only grid/mobile-only slider topology.",
  "checks": [
    {
      "id": "services-desktop-grid",
      "description": "Our Services keeps the source two-column desktop grid.",
      "selector": ".services-grid",
      "property": "grid-template-columns",
      "expected": "1fr 1fr",
      "severity": "error"
    },
    {
      "id": "services-grid-gap",
      "description": "Our Services keeps the source 16px card gutter.",
      "selector": ".services-grid",
      "property": "gap",
      "expected": "16px",
      "severity": "error"
    },
    {
      "id": "services-card-columns",
      "description": "Desktop cards keep the source text-to-photo split.",
      "selector": ".services-item",
      "property": "grid-template-columns",
      "expected": ".5fr 1fr",
      "severity": "error"
    },
    {
      "id": "services-card-padding",
      "description": "Desktop cards keep the source inset geometry.",
      "selector": ".services-item",
      "property": "padding",
      "expected": "20px 20px 40px 40px",
      "severity": "error"
    },
    {
      "id": "services-copy-leading",
      "description": "Service copy inherits the source 1.5 reading rhythm.",
      "selector": ".service-item-description",
      "property": "line-height",
      "expected": "1.5",
      "severity": "error"
    },
    {
      "id": "services-photo-aspect",
      "description": "Local service photos keep the measured source composite proportion near 398x449.",
      "selector": ".image",
      "property": "aspect-ratio",
      "expected": "398 / 449",
      "severity": "error"
    },
    {
      "id": "services-photo-not-regular-ellipse",
      "description": "The source does not use border-radius for the service photo contour; the organic alpha contour must remain independently clipped.",
      "selector": ".image",
      "property": "border-radius",
      "expected": "0",
      "severity": "error"
    },
    {
      "id": "services-photo-no-concentric-shadow",
      "description": "The source outer hairline is not a concentric box-shadow ring.",
      "selector": ".image",
      "property": "box-shadow",
      "expected": "none",
      "severity": "error"
    },
    {
      "id": "services-photo-organic-mask",
      "description": "Each local service photo is clipped by its measured organic inner contour.",
      "selector": ".image",
      "property": "clip-path",
      "expected": "var(--service-photo-mask)",
      "severity": "error"
    },
    {
      "id": "services-outline-independent-layer",
      "description": "The differently shaped outer hairline remains an independent scalable layer over the photo mask.",
      "selector": ".service-image-outline",
      "property": "position",
      "expected": "absolute",
      "severity": "error"
    },
    {
      "id": "services-desktop-slider-hidden",
      "description": "The mobile Swiper cannot leak below the desktop 2x2 grid.",
      "selector": "#Services .services-slider",
      "property": "display",
      "expected": "none",
      "severity": "error"
    },
    {
      "id": "standards-heading-source-offset",
      "description": "The Standards heading keeps the source 20px top offset inside the section.",
      "selector": "#Standarts h2",
      "property": "margin-top",
      "expected": "20px",
      "severity": "error"
    },
    {
      "id": "standards-grid-source-gutter",
      "description": "Standards keeps the source three-column 69px gutter.",
      "selector": ".standarts-wrapp",
      "property": "gap",
      "expected": "69px",
      "severity": "error"
    },
    {
      "id": "standards-grid-source-rhythm",
      "description": "Standards keeps the source 120px heading-to-grid desktop rhythm.",
      "selector": ".standarts-wrapp",
      "property": "margin-top",
      "expected": "120px",
      "severity": "error"
    },
    {
      "id": "standards-card-source-gap",
      "description": "Each icon composition and copy block keep the source 36px separation.",
      "selector": ".standart-item",
      "property": "gap",
      "expected": "36px",
      "severity": "error"
    },
    {
      "id": "standards-disk-source-size",
      "description": "The peach icon disk keeps the source 169px desktop diameter.",
      "selector": ".standart-image-wrapp",
      "property": "width",
      "expected": "169px",
      "severity": "error"
    },
    {
      "id": "standards-outline-independent-layer",
      "description": "The decorative hairline remains a separate absolute layer behind the disk.",
      "selector": ".service-image-absolute",
      "property": "position",
      "expected": "absolute",
      "severity": "error"
    },
    {
      "id": "standards-outline-not-concentric-circle",
      "description": "The source outline is irregular and cannot regress to a regular circular ring.",
      "selector": ".service-image-absolute",
      "property": "border-radius",
      "expected": "40% 60% 55% 45% / 30% 42% 58% 70%",
      "severity": "error"
    },
    {
      "id": "standards-copy-source-leading",
      "description": "Standards copy keeps the source 24px line height at the 16px body scale.",
      "selector": ".service-text",
      "property": "line-height",
      "expected": "1.5",
      "severity": "error"
    }
  ],
  "design_tokens": {
    "fonts": {
      "heading": "Forum, serif",
      "body": "Cormorant, serif",
      "accent": "Open Sans, sans-serif"
    },
    "colors": {
      "paper": "#fdfaf7",
      "ink": "#000000",
      "warmBeige": "#f8e8da",
      "peach": "#f8c497",
      "white": "#ffffff",
      "dark": "#1f2024",
      "line": "#ece0dc"
    }
  },
  "sections": [
    "booking-popup-modal",
    "navbar-fixed-transparent",
    "hero-split-layout",
    "services-4-card-grid",
    "standards-3-icon-cards",
    "pricing-accordion-dropdowns",
    "gallery-5-image-masonry",
    "reviews-3-testimonials",
    "contact-phone-form",
    "footer-logo-info-social-menu"
  ],
  "visual_slots": {
    "hero": { "family": "photography", "count": 1, "aspect": "670x589" },
    "services": { "family": "photography", "count": 4, "aspect": "405x455" },
    "pricing": { "family": "photography", "count": 1, "aspect": "547x814" },
    "gallery": { "family": "photography", "count": 5, "aspect": "mixed" },
    "form_decor": { "family": "photography", "count": 1, "aspect": "square" },
    "popup": { "family": "photography", "count": 1, "aspect": "square" },
    "standards_icons": { "family": "svg-icon", "count": 3 },
    "social_icons": { "family": "svg-icon", "count": 3 }
  },
  "typography_scale": {
    "h1": "96px desktop / 48px tablet",
    "h2": "36px desktop / 32px tablet",
    "body": "16px",
    "hero_subhead": "24px",
    "service_heading": "24px",
    "pricing_dropdown": "24px",
